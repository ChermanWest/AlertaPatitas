# Copia este archivo a ".env" y completa con los datos de tu proyecto Supabase
# (Project Settings → API en supabase.com). Vite solo expone variables que
# empiecen con VITE_, y este archivo NUNCA debe subirse a un repo público
# con valores reales (agrega ".env" a tu .gitignore).

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui
